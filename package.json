{
  "name": "@leash/sdk",
  "version": "0.2.2",
  "description": "TypeScript SDK for Leash platform - authentication and environment management",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./integrations": {
      "types": "./dist/integrations/index.d.ts",
      "default": "./dist/integrations/index.js"
    },
    "./integrations/mcp": {
      "types": "./dist/integrations/mcp.d.ts",
      "default": "./dist/integrations/mcp.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "leash",
    "authentication",
    "nextjs",
    "react",
    "typescript"
  ],
  "author": "Leash",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0",
    "next": "^13.0.0 || ^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.0",
    "@types/jsonwebtoken": "^9.0.0"
  }
}
